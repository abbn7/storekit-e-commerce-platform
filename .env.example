# ═══════════════════════════════════════════════════════════════
#  StoreKit — Environment Variables Template
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────
# For Docker Compose: uses internal postgres service (auto-set)
# For external DB (Neon, Supabase, Railway, etc.):
DATABASE_URL=postgresql://user:password@localhost:5432/storekit

# Docker Compose postgres credentials (only used by docker-compose.yml)
POSTGRES_DB=storekit
POSTGRES_USER=storekit
POSTGRES_PASSWORD=change-me-strong-password

# ── App ─────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# Random secret for session signing — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Admin Dashboard ─────────────────────────────────────────────
ADMIN_PASSWORD=storekit2024

# ── Clerk Authentication (optional — storefront user accounts) ──
# Get keys from: https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_live_xxxx
CLERK_SECRET_KEY=sk_live_xxxx

# ── Stripe Payments (optional) ──────────────────────────────────
# Get keys from: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_xxxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx

# ── Email / SMTP (optional — for stock alerts & order emails) ───
# Works with Gmail, Mailgun, SendGrid, Postmark, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=StoreKit <noreply@yourdomain.com>

# ── File Storage ────────────────────────────────────────────────
# Directory where uploaded product images are stored
# Use absolute path in production
UPLOAD_DIR=./uploads

# Path to built frontend static files (for Docker/production)
FRONTEND_DIST=./public
